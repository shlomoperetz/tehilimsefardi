{
  "number": 119,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "אַשְׁרֵ֥י תְמִֽימֵי־דָ֑רֶךְ הַ֝הֹלְכִ֗ים בְּתוֹרַ֥ת יְהֹוָֽה׃",
      "he_plain": "אשרי תמימידרך ההלכים בתורת יהוה",
      "translit": "",
      "es": ""
    },
    {
      "num": 2,
      "he": "אַ֭שְׁרֵי נֹצְרֵ֥י עֵדֹתָ֗יו בְּכׇל־לֵ֥ב יִדְרְשֽׁוּהוּ׃",
      "he_plain": "אשרי נצרי עדתיו בכללב ידרשוהו",
      "translit": "",
      "es": ""
    },
    {
      "num": 3,
      "he": "אַ֭ף לֹא־פָעֲל֣וּ עַוְלָ֑ה בִּדְרָכָ֥יו הָלָֽכוּ׃",
      "he_plain": "אף לאפעלו עולה בדרכיו הלכו",
      "translit": "",
      "es": ""
    },
    {
      "num": 4,
      "he": "אַ֭תָּה צִוִּ֥יתָה פִקֻּדֶ֗יךָ לִשְׁמֹ֥ר מְאֹֽד׃",
      "he_plain": "אתה צויתה פקדיך לשמר מאד",
      "translit": "",
      "es": ""
    },
    {
      "num": 5,
      "he": "אַ֭חֲלַי יִכֹּ֥נוּ דְרָכָ֗י לִשְׁמֹ֥ר חֻקֶּֽיךָ׃",
      "he_plain": "אחלי יכנו דרכי לשמר חקיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 6,
      "he": "אָ֥ז לֹא־אֵב֑וֹשׁ בְּ֝הַבִּיטִ֗י אֶל־כׇּל־מִצְוֺתֶֽיךָ׃",
      "he_plain": "אז לאאבוש בהביטי אלכלמצותיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 7,
      "he": "א֭וֹדְךָ בְּיֹ֣שֶׁר לֵבָ֑ב בְּ֝לׇמְדִ֗י מִשְׁפְּטֵ֥י צִדְקֶֽךָ׃",
      "he_plain": "אודך בישר לבב בלמדי משפטי צדקך",
      "translit": "",
      "es": ""
    },
    {
      "num": 8,
      "he": "אֶת־חֻקֶּ֥יךָ אֶשְׁמֹ֑ר אַֽל־תַּעַזְבֵ֥נִי עַד־מְאֹֽד׃ {פ}",
      "he_plain": "אתחקיך אשמר אלתעזבני עדמאד {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 9,
      "he": "בַּמֶּ֣ה יְזַכֶּה־נַּ֭עַר אֶת־אׇרְח֑וֹ לִ֝שְׁמֹ֗ר כִּדְבָרֶֽךָ׃",
      "he_plain": "במה יזכהנער אתארחו לשמר כדברך",
      "translit": "",
      "es": ""
    },
    {
      "num": 10,
      "he": "בְּכׇל־לִבִּ֥י דְרַשְׁתִּ֑יךָ אַל־תַּ֝שְׁגֵּ֗נִי מִמִּצְוֺתֶֽיךָ׃",
      "he_plain": "בכללבי דרשתיך אלתשגני ממצותיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 11,
      "he": "בְּ֭לִבִּי צָפַ֣נְתִּי אִמְרָתֶ֑ךָ לְ֝מַ֗עַן לֹ֣א אֶחֱטָא־לָֽךְ׃",
      "he_plain": "בלבי צפנתי אמרתך למען לא אחטאלך",
      "translit": "",
      "es": ""
    },
    {
      "num": 12,
      "he": "בָּר֖וּךְ אַתָּ֥ה יְהֹוָ֗ה לַמְּדֵ֥נִי חֻקֶּֽיךָ׃",
      "he_plain": "ברוך אתה יהוה למדני חקיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 13,
      "he": "בִּשְׂפָתַ֥י סִפַּ֑רְתִּי כֹּ֝֗ל מִשְׁפְּטֵי־פִֽיךָ׃",
      "he_plain": "בשפתי ספרתי כל משפטיפיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 14,
      "he": "בְּדֶ֖רֶךְ עֵדְוֺתֶ֥יךָ שַּׂ֗שְׂתִּי כְּעַ֣ל כׇּל־הֽוֹן׃",
      "he_plain": "בדרך עדותיך ששתי כעל כלהון",
      "translit": "",
      "es": ""
    },
    {
      "num": 15,
      "he": "בְּפִקּוּדֶ֥יךָ אָשִׂ֑יחָה וְ֝אַבִּ֗יטָה אֹֽרְחֹתֶֽיךָ׃",
      "he_plain": "בפקודיך אשיחה ואביטה ארחתיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 16,
      "he": "בְּחֻקֹּתֶ֥יךָ אֶֽשְׁתַּעֲשָׁ֑ע לֹ֖א אֶשְׁכַּ֣ח דְּבָרֶֽךָ׃ {פ}",
      "he_plain": "בחקתיך אשתעשע לא אשכח דברך {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 17,
      "he": "גְּמֹ֖ל עַל־עַבְדְּךָ֥ אֶחְיֶ֗ה וְאֶשְׁמְרָ֥ה דְבָרֶֽךָ׃",
      "he_plain": "גמל עלעבדך אחיה ואשמרה דברך",
      "translit": "",
      "es": ""
    },
    {
      "num": 18,
      "he": "גַּל־עֵינַ֥י וְאַבִּ֑יטָה נִ֝פְלָא֗וֹת מִתּוֹרָתֶֽךָ׃",
      "he_plain": "גלעיני ואביטה נפלאות מתורתך",
      "translit": "",
      "es": ""
    },
    {
      "num": 19,
      "he": "גֵּ֣ר אָנֹכִ֣י בָאָ֑רֶץ אַל־תַּסְתֵּ֥ר מִ֝מֶּ֗נִּי מִצְוֺתֶֽיךָ׃",
      "he_plain": "גר אנכי בארץ אלתסתר ממני מצותיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 20,
      "he": "גָּרְסָ֣ה נַפְשִׁ֣י לְתַאֲבָ֑ה אֶֽל־מִשְׁפָּטֶ֥יךָ בְכׇל־עֵֽת׃",
      "he_plain": "גרסה נפשי לתאבה אלמשפטיך בכלעת",
      "translit": "",
      "es": ""
    },
    {
      "num": 21,
      "he": "גָּ֭עַרְתָּ זֵדִ֣ים אֲרוּרִ֑ים הַ֝שֹּׁגִ֗ים מִמִּצְוֺתֶֽיךָ׃",
      "he_plain": "גערת זדים ארורים השגים ממצותיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 22,
      "he": "גַּ֣ל מֵ֭עָלַי חֶרְפָּ֣ה וָב֑וּז כִּ֖י עֵדֹתֶ֣יךָ נָצָֽרְתִּי׃",
      "he_plain": "גל מעלי חרפה ובוז כי עדתיך נצרתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 23,
      "he": "גַּ֤ם יָשְׁב֣וּ שָׂ֭רִים בִּ֣י נִדְבָּ֑רוּ עַ֝בְדְּךָ֗ יָשִׂ֥יחַ בְּחֻקֶּֽיךָ׃",
      "he_plain": "גם ישבו שרים בי נדברו עבדך ישיח בחקיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 24,
      "he": "גַּֽם־עֵ֭דֹתֶיךָ שַׁעֲשֻׁעָ֗י אַנְשֵׁ֥י עֲצָתִֽי׃ {פ}",
      "he_plain": "גםעדתיך שעשעי אנשי עצתי {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 25,
      "he": "דָּבְקָ֣ה לֶעָפָ֣ר נַפְשִׁ֑י חַ֝יֵּ֗נִי כִּדְבָרֶֽךָ׃",
      "he_plain": "דבקה לעפר נפשי חיני כדברך",
      "translit": "",
      "es": ""
    },
    {
      "num": 26,
      "he": "דְּרָכַ֣י סִ֭פַּרְתִּי וַֽתַּעֲנֵ֗נִי לַמְּדֵ֥נִי חֻקֶּֽיךָ׃",
      "he_plain": "דרכי ספרתי ותענני למדני חקיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 27,
      "he": "דֶּרֶךְ־פִּקּוּדֶ֥יךָ הֲבִינֵ֑נִי וְ֝אָשִׂ֗יחָה בְּנִפְלְאוֹתֶֽיךָ׃",
      "he_plain": "דרךפקודיך הבינני ואשיחה בנפלאותיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 28,
      "he": "דָּלְפָ֣ה נַ֭פְשִׁי מִתּוּגָ֑ה קַ֝יְּמֵ֗נִי כִּדְבָרֶֽךָ׃",
      "he_plain": "דלפה נפשי מתוגה קימני כדברך",
      "translit": "",
      "es": ""
    },
    {
      "num": 29,
      "he": "דֶּֽרֶךְ־שֶׁ֭קֶר הָסֵ֣ר מִמֶּ֑נִּי וְֽתוֹרָתְךָ֥ חׇנֵּֽנִי׃",
      "he_plain": "דרךשקר הסר ממני ותורתך חנני",
      "translit": "",
      "es": ""
    },
    {
      "num": 30,
      "he": "דֶּֽרֶךְ־אֱמוּנָ֥ה בָחָ֑רְתִּי מִשְׁפָּטֶ֥יךָ שִׁוִּֽיתִי׃",
      "he_plain": "דרךאמונה בחרתי משפטיך שויתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 31,
      "he": "דָּבַ֥קְתִּי בְעֵדְוֺתֶ֑יךָ יְ֝הֹוָ֗ה אַל־תְּבִישֵֽׁנִי׃",
      "he_plain": "דבקתי בעדותיך יהוה אלתבישני",
      "translit": "",
      "es": ""
    },
    {
      "num": 32,
      "he": "דֶּֽרֶךְ־מִצְוֺתֶ֥יךָ אָר֑וּץ כִּ֖י תַרְחִ֣יב לִבִּֽי׃ {פ}",
      "he_plain": "דרךמצותיך ארוץ כי תרחיב לבי {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 33,
      "he": "הוֹרֵ֣נִי יְ֭הֹוָה דֶּ֥רֶךְ חֻקֶּ֗יךָ וְאֶצְּרֶ֥נָּה עֵֽקֶב׃",
      "he_plain": "הורני יהוה דרך חקיך ואצרנה עקב",
      "translit": "",
      "es": ""
    },
    {
      "num": 34,
      "he": "הֲ֭בִינֵנִי וְאֶצְּרָ֥ה תוֹרָתֶ֗ךָ וְאֶשְׁמְרֶ֥נָּה בְכׇל־לֵֽב׃",
      "he_plain": "הבינני ואצרה תורתך ואשמרנה בכללב",
      "translit": "",
      "es": ""
    },
    {
      "num": 35,
      "he": "הַ֭דְרִיכֵנִי בִּנְתִ֣יב מִצְוֺתֶ֑יךָ כִּי־ב֥וֹ חָפָֽצְתִּי׃",
      "he_plain": "הדריכני בנתיב מצותיך כיבו חפצתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 36,
      "he": "הַט־לִ֭בִּי אֶל־עֵדְוֺתֶ֗יךָ וְאַ֣ל אֶל־בָּֽצַע׃",
      "he_plain": "הטלבי אלעדותיך ואל אלבצע",
      "translit": "",
      "es": ""
    },
    {
      "num": 37,
      "he": "הַעֲבֵ֣ר עֵ֭ינַי מֵרְא֣וֹת שָׁ֑וְא בִּדְרָכֶ֥ךָ חַיֵּֽנִי׃",
      "he_plain": "העבר עיני מראות שוא בדרכך חיני",
      "translit": "",
      "es": ""
    },
    {
      "num": 38,
      "he": "הָקֵ֣ם לְ֭עַבְדְּךָ אִמְרָתֶ֑ךָ אֲ֝שֶׁ֗ר לְיִרְאָתֶֽךָ׃",
      "he_plain": "הקם לעבדך אמרתך אשר ליראתך",
      "translit": "",
      "es": ""
    },
    {
      "num": 39,
      "he": "הַעֲבֵ֣ר חֶ֭רְפָּתִי אֲשֶׁ֣ר יָגֹ֑רְתִּי כִּ֖י מִשְׁפָּטֶ֣יךָ טוֹבִֽים׃",
      "he_plain": "העבר חרפתי אשר יגרתי כי משפטיך טובים",
      "translit": "",
      "es": ""
    },
    {
      "num": 40,
      "he": "הִ֭נֵּה תָּאַ֣בְתִּי לְפִקֻּדֶ֑יךָ בְּצִדְקָתְךָ֥ חַיֵּֽנִי׃ {פ}",
      "he_plain": "הנה תאבתי לפקדיך בצדקתך חיני {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 41,
      "he": "וִיבֹאֻ֣נִי חֲסָדֶ֣ךָ יְהֹוָ֑ה תְּ֝שׁ֥וּעָתְךָ֗ כְּאִמְרָתֶֽךָ׃",
      "he_plain": "ויבאני חסדך יהוה תשועתך כאמרתך",
      "translit": "",
      "es": ""
    },
    {
      "num": 42,
      "he": "וְאֶעֱנֶ֣ה חֹרְפִ֣י דָבָ֑ר כִּֽי־בָ֝טַ֗חְתִּי בִּדְבָרֶֽךָ׃",
      "he_plain": "ואענה חרפי דבר כיבטחתי בדברך",
      "translit": "",
      "es": ""
    },
    {
      "num": 43,
      "he": "וְֽאַל־תַּצֵּ֬ל מִפִּ֣י דְבַר־אֱמֶ֣ת עַד־מְאֹ֑ד כִּ֖י לְמִשְׁפָּטֶ֣ךָ יִחָֽלְתִּי׃",
      "he_plain": "ואלתצל מפי דבראמת עדמאד כי למשפטך יחלתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 44,
      "he": "וְאֶשְׁמְרָ֖ה תוֹרָתְךָ֥ תָמִ֗יד לְעוֹלָ֥ם וָעֶֽד׃",
      "he_plain": "ואשמרה תורתך תמיד לעולם ועד",
      "translit": "",
      "es": ""
    },
    {
      "num": 45,
      "he": "וְאֶתְהַלְּכָ֥ה בָרְחָבָ֑ה כִּ֖י פִקֻּדֶ֣יךָ דָרָֽשְׁתִּי׃",
      "he_plain": "ואתהלכה ברחבה כי פקדיך דרשתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 46,
      "he": "וַאֲדַבְּרָ֣ה בְ֭עֵדֹתֶיךָ נֶ֥גֶד מְלָכִ֗ים וְלֹ֣א אֵבֽוֹשׁ׃",
      "he_plain": "ואדברה בעדתיך נגד מלכים ולא אבוש",
      "translit": "",
      "es": ""
    },
    {
      "num": 47,
      "he": "וְאֶשְׁתַּעֲשַׁ֥ע בְּמִצְוֺתֶ֗יךָ אֲשֶׁ֣ר אָהָֽבְתִּי׃",
      "he_plain": "ואשתעשע במצותיך אשר אהבתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 48,
      "he": "וְאֶשָּֽׂא־כַפַּ֗י אֶֽל־מִ֭צְוֺתֶיךָ אֲשֶׁ֥ר אָהָ֗בְתִּי וְאָשִׂ֥יחָה בְחֻקֶּֽיךָ׃ {פ}",
      "he_plain": "ואשאכפי אלמצותיך אשר אהבתי ואשיחה בחקיך {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 49,
      "he": "זְכֹר־דָּבָ֥ר לְעַבְדֶּ֑ךָ עַ֝֗ל אֲשֶׁ֣ר יִחַלְתָּֽנִי׃",
      "he_plain": "זכרדבר לעבדך על אשר יחלתני",
      "translit": "",
      "es": ""
    },
    {
      "num": 50,
      "he": "זֹ֣את נֶחָמָתִ֣י בְעׇנְיִ֑י כִּ֖י אִמְרָתְךָ֣ חִיָּֽתְנִי׃",
      "he_plain": "זאת נחמתי בעניי כי אמרתך חיתני",
      "translit": "",
      "es": ""
    },
    {
      "num": 51,
      "he": "זֵ֭דִים הֱלִיצֻ֣נִי עַד־מְאֹ֑ד מִ֝תּ֥וֹרָתְךָ֗ לֹ֣א נָטִֽיתִי׃",
      "he_plain": "זדים הליצני עדמאד מתורתך לא נטיתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 52,
      "he": "זָ֘כַ֤רְתִּי מִשְׁפָּטֶ֖יךָ מֵעוֹלָ֥ם׀יְהֹוָ֗ה וָאֶתְנֶחָֽם׃",
      "he_plain": "זכרתי משפטיך מעולםיהוה ואתנחם",
      "translit": "",
      "es": ""
    },
    {
      "num": 53,
      "he": "זַלְעָפָ֣ה אֲ֭חָזַתְנִי מֵרְשָׁעִ֑ים עֹ֝זְבֵ֗י תּוֹרָתֶֽךָ׃",
      "he_plain": "זלעפה אחזתני מרשעים עזבי תורתך",
