    {
      "num": 54,
      "he": "זְ֭מִרוֹת הָיוּ־לִ֥י חֻקֶּ֗יךָ בְּבֵ֣ית מְגוּרָֽי׃",
      "he_plain": "זמרות היולי חקיך בבית מגורי",
      "translit": "",
      "es": ""
    },
    {
      "num": 55,
      "he": "זָ֘כַ֤רְתִּי בַלַּ֣יְלָה שִׁמְךָ֣ יְהֹוָ֑ה וָ֝אֶשְׁמְרָ֗ה תּוֹרָתֶֽךָ׃",
      "he_plain": "זכרתי בלילה שמך יהוה ואשמרה תורתך",
      "translit": "",
      "es": ""
    },
    {
      "num": 56,
      "he": "זֹ֥את הָיְתָה־לִּ֑י כִּ֖י פִקֻּדֶ֣יךָ נָצָֽרְתִּי׃ {פ}",
      "he_plain": "זאת היתהלי כי פקדיך נצרתי {פ}",
      "translit": "",
      "es": ""
