    {
      "num": 147,
      "he": "קִדַּ֣מְתִּי בַ֭נֶּשֶׁף וָאֲשַׁוֵּ֑עָה (לדבריך) [לִדְבָרְךָ֥] יִחָֽלְתִּי׃",
      "he_plain": "קדמתי בנשף ואשועה (לדבריך) [לדברך] יחלתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 148,
      "he": "קִדְּמ֣וּ עֵ֭ינַי אַשְׁמֻר֑וֹת לָ֝שִׂ֗יחַ בְּאִמְרָתֶֽךָ׃",
      "he_plain": "קדמו עיני אשמרות לשיח באמרתך",
      "translit": "",
      "es": ""
    },
    {
      "num": 149,
      "he": "ק֭וֹלִי שִׁמְעָ֣ה כְחַסְדֶּ֑ךָ יְ֝הֹוָ֗ה כְּֽמִשְׁפָּטֶ֥ךָ חַיֵּֽנִי׃",
      "he_plain": "קולי שמעה כחסדך יהוה כמשפטך חיני",
      "translit": "",
      "es": ""
    },
    {
      "num": 150,
      "he": "קָ֭רְבוּ רֹדְפֵ֣י זִמָּ֑ה מִתּוֹרָתְךָ֥ רָחָֽקוּ׃",
      "he_plain": "קרבו רדפי זמה מתורתך רחקו",
      "translit": "",
      "es": ""
    },
    {
      "num": 151,
      "he": "קָר֣וֹב אַתָּ֣ה יְהֹוָ֑ה וְֽכׇל־מִצְוֺתֶ֥יךָ אֱמֶֽת׃",
      "he_plain": "קרוב אתה יהוה וכלמצותיך אמת",
      "translit": "",
      "es": ""
    },
    {
      "num": 152,
      "he": "קֶ֣דֶם יָ֭דַעְתִּי מֵעֵדֹתֶ֑יךָ כִּ֖י לְעוֹלָ֣ם יְסַדְתָּֽם׃ {פ}",
      "he_plain": "קדם ידעתי מעדתיך כי לעולם יסדתם {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 153,
      "he": "רְאֵה־עׇנְיִ֥י וְחַלְּצֵ֑נִי כִּי־ת֥֝וֹרָתְךָ֗ לֹ֣א שָׁכָֽחְתִּי׃",
      "he_plain": "ראהעניי וחלצני כיתורתך לא שכחתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 154,
      "he": "רִיבָ֣ה רִ֭יבִי וּגְאָלֵ֑נִי לְאִמְרָתְךָ֥ חַיֵּֽנִי׃",
      "he_plain": "ריבה ריבי וגאלני לאמרתך חיני",
      "translit": "",
      "es": ""
    },
    {
      "num": 155,
      "he": "רָח֣וֹק מֵרְשָׁעִ֣ים יְשׁוּעָ֑ה כִּי־חֻ֝קֶּ֗יךָ לֹ֣א דָרָֽשׁוּ׃",
      "he_plain": "רחוק מרשעים ישועה כיחקיך לא דרשו",
      "translit": "",
      "es": ""
    },
    {
      "num": 156,
      "he": "רַחֲמֶ֖יךָ רַבִּ֥ים׀יְהֹוָ֑ה כְּֽמִשְׁפָּטֶ֥יךָ חַיֵּֽנִי׃",
      "he_plain": "רחמיך רביםיהוה כמשפטיך חיני",
      "translit": "",
      "es": ""
    },
    {
      "num": 157,
      "he": "רַ֭בִּים רֹדְפַ֣י וְצָרָ֑י מֵ֝עֵדְוֺתֶ֗יךָ לֹ֣א נָטִֽיתִי׃",
      "he_plain": "רבים רדפי וצרי מעדותיך לא נטיתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 158,
      "he": "רָאִ֣יתִי בֹ֭גְדִים וָאֶתְקוֹטָ֑טָה אֲשֶׁ֥ר אִ֝מְרָתְךָ֗ לֹ֣א שָׁמָֽרוּ׃",
      "he_plain": "ראיתי בגדים ואתקוטטה אשר אמרתך לא שמרו",
      "translit": "",
      "es": ""
    },
    {
      "num": 159,
      "he": "רְ֭אֵה כִּי־פִקּוּדֶ֣יךָ אָהָ֑בְתִּי יְ֝הֹוָ֗ה כְּֽחַסְדְּךָ֥ חַיֵּֽנִי׃",
      "he_plain": "ראה כיפקודיך אהבתי יהוה כחסדך חיני",
      "translit": "",
      "es": ""
    },
    {
      "num": 160,
      "he": "רֹאשׁ־דְּבָרְךָ֥ אֱמֶ֑ת וּ֝לְעוֹלָ֗ם כׇּל־מִשְׁפַּ֥ט צִדְקֶֽךָ׃ {פ}",
      "he_plain": "ראשדברך אמת ולעולם כלמשפט צדקך {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 161,
      "he": "שָׂ֭רִים רְדָפ֣וּנִי חִנָּ֑ם (ומדבריך) [וּ֝מִדְּבָרְךָ֗] פָּחַ֥ד לִבִּֽי׃",
      "he_plain": "שרים רדפוני חנם (ומדבריך) [ומדברך] פחד לבי",
      "translit": "",
      "es": ""
    },
    {
      "num": 162,
      "he": "שָׂ֣שׂ אָ֭נֹכִי עַל־אִמְרָתֶ֑ךָ כְּ֝מוֹצֵ֗א שָׁלָ֥ל רָֽב׃",
      "he_plain": "שש אנכי עלאמרתך כמוצא שלל רב",
      "translit": "",
      "es": ""
    },
    {
      "num": 163,
      "he": "שֶׁ֣קֶר שָׂ֭נֵאתִי וַאֲתַעֵ֑בָה תּוֹרָתְךָ֥ אָהָֽבְתִּי׃",
      "he_plain": "שקר שנאתי ואתעבה תורתך אהבתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 164,
      "he": "שֶׁ֣בַע בַּ֭יּוֹם הִלַּלְתִּ֑יךָ עַ֝֗ל מִשְׁפְּטֵ֥י צִדְקֶֽךָ׃",
      "he_plain": "שבע ביום הללתיך על משפטי צדקך",
      "translit": "",
      "es": ""
    },
    {
      "num": 165,
      "he": "שָׁל֣וֹם רָ֭ב לְאֹהֲבֵ֣י תוֹרָתֶ֑ךָ וְאֵֽין־לָ֥מוֹ מִכְשֽׁוֹל׃",
      "he_plain": "שלום רב לאהבי תורתך ואיןלמו מכשול",
      "translit": "",
      "es": ""
    },
    {
      "num": 166,
      "he": "שִׂבַּ֣רְתִּי לִישׁוּעָתְךָ֣ יְהֹוָ֑ה וּֽמִצְוֺתֶ֥יךָ עָשִֽׂיתִי׃",
      "he_plain": "שברתי לישועתך יהוה ומצותיך עשיתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 167,
      "he": "שָֽׁמְרָ֣ה נַ֭פְשִׁי עֵדֹתֶ֑יךָ וָאֹהֲבֵ֥ם מְאֹֽד׃",
      "he_plain": "שמרה נפשי עדתיך ואהבם מאד",
      "translit": "",
      "es": ""
    },
    {
      "num": 168,
      "he": "שָׁמַ֣רְתִּי פִ֭קּוּדֶיךָ וְעֵדֹתֶ֑יךָ כִּ֖י כׇל־דְּרָכַ֣י נֶגְדֶּֽךָ׃ {פ}",
      "he_plain": "שמרתי פקודיך ועדתיך כי כלדרכי נגדך {פ}",
      "translit": "",
      "es": ""
    },
    {
      "num": 169,
      "he": "תִּקְרַ֤ב רִנָּתִ֣י לְפָנֶ֣יךָ יְהֹוָ֑ה כִּדְבָרְךָ֥ הֲבִינֵֽנִי׃",
      "he_plain": "תקרב רנתי לפניך יהוה כדברך הבינני",
      "translit": "",
      "es": ""
    },
    {
      "num": 170,
      "he": "תָּב֣וֹא תְחִנָּתִ֣י לְפָנֶ֑יךָ כְּ֝אִמְרָתְךָ֗ הַצִּילֵֽנִי׃",
      "he_plain": "תבוא תחנתי לפניך כאמרתך הצילני",
      "translit": "",
      "es": ""
    },
    {
      "num": 171,
      "he": "תַּבַּ֣עְנָה שְׂפָתַ֣י תְּהִלָּ֑ה כִּ֖י תְלַמְּדֵ֣נִי חֻקֶּֽיךָ׃",
      "he_plain": "תבענה שפתי תהלה כי תלמדני חקיך",
      "translit": "",
      "es": ""
    },
    {
      "num": 172,
      "he": "תַּ֣עַן לְ֭שׁוֹנִי אִמְרָתֶ֑ךָ כִּ֖י כׇל־מִצְוֺתֶ֣יךָ צֶּֽדֶק׃",
      "he_plain": "תען לשוני אמרתך כי כלמצותיך צדק",
      "translit": "",
      "es": ""
    },
    {
      "num": 173,
      "he": "תְּהִי־יָדְךָ֥ לְעׇזְרֵ֑נִי כִּ֖י פִקּוּדֶ֣יךָ בָחָֽרְתִּי׃",
      "he_plain": "תהיידך לעזרני כי פקודיך בחרתי",
      "translit": "",
      "es": ""
    },
    {
      "num": 174,
      "he": "תָּאַ֣בְתִּי לִישׁוּעָתְךָ֣ יְהֹוָ֑ה וְ֝ת֥וֹרָתְךָ֗ שַׁעֲשֻׁעָֽי׃",
      "he_plain": "תאבתי לישועתך יהוה ותורתך שעשעי",
      "translit": "",
      "es": ""
    },
    {
      "num": 175,
      "he": "תְּֽחִי־נַ֭פְשִׁי וּֽתְהַלְלֶ֑ךָּ וּֽמִשְׁפָּטֶ֥ךָ יַעְזְרֻֽנִי׃",
      "he_plain": "תחינפשי ותהללך ומשפטך יעזרני",
      "translit": "",
      "es": ""
    },
    {
      "num": 176,
      "he": "תָּעִ֗יתִי כְּשֶׂ֣ה אֹ֭בֵד בַּקֵּ֣שׁ עַבְדֶּ֑ךָ כִּ֥י מִ֝צְוֺתֶ֗יךָ לֹ֣א שָׁכָֽחְתִּי׃ {פ}",
      "he_plain": "תעיתי כשה אבד בקש עבדך כי מצותיך לא שכחתי {פ}",
      "translit": "",
      "es": ""
    }
  ],
  "audio": ""
}