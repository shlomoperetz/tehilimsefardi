{
  "number": 30,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "מִזְמ֡וֹר שִׁיר־חֲנֻכַּ֖ת הַבַּ֣יִת לְדָוִֽד׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 2,
      "he": "אֲרוֹמִמְךָ֣ יְ֭הֹוָה כִּ֣י דִלִּיתָ֑נִי וְלֹֽא־שִׂמַּ֖חְתָּ אֹיְבַ֣י לִֽי׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 3,
      "he": "יְהֹוָ֥ה אֱלֹהָ֑י שִׁוַּ֥עְתִּי אֵ֝לֶ֗יךָ וַתִּרְפָּאֵֽנִי׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 4,
      "he": "יְֽהֹוָ֗ה הֶעֱלִ֣יתָ מִן־שְׁא֣וֹל נַפְשִׁ֑י חִ֝יִּיתַ֗נִי (מיורדי) [מִיׇּֽרְדִי־]בֽוֹר׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 5,
      "he": "זַמְּר֣וּ לַיהֹוָ֣ה חֲסִידָ֑יו וְ֝הוֹד֗וּ לְזֵ֣כֶר קׇדְשֽׁוֹ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 6,
      "he": "כִּ֤י רֶ֨גַע&thinsp;׀ בְּאַפּוֹ֮ חַיִּ֢ים בִּרְצ֫וֹנ֥וֹ בָּ֭עֶרֶב יָלִ֥ין בֶּ֗כִי וְלַבֹּ֥קֶר רִנָּֽה׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 7,
      "he": "וַ֭אֲנִי אָמַ֣רְתִּי בְשַׁלְוִ֑י בַּל־אֶמּ֥וֹט לְעוֹלָֽם׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 8,
      "he": "יְֽהֹוָ֗ה בִּרְצוֹנְךָ֮ הֶעֱמַ֢דְתָּה לְֽהַרְרִ֫י־עֹ֥ז הִסְתַּ֥רְתָּ פָנֶ֗יךָ הָיִ֥יתִי נִבְהָֽל׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 9,
      "he": "אֵלֶ֣יךָ יְהֹוָ֣ה אֶקְרָ֑א וְאֶל־אֲ֝דֹנָ֗י אֶתְחַנָּֽן׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 10,
      "he": "מַה־בֶּ֥צַע בְּדָמִי֮ בְּרִדְתִּ֢י אֶ֫ל־שָׁ֥חַת הֲיוֹדְךָ֥ עָפָ֑ר הֲיַגִּ֥יד אֲמִתֶּֽךָ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 11,
      "he": "שְׁמַע־יְהֹוָ֥ה וְחׇנֵּ֑נִי יְ֝הֹוָ֗ה הֱֽיֵה־עֹזֵ֥ר לִֽי׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 12,
      "he": "הָפַ֣כְתָּ מִסְפְּדִי֮ לְמָח֢וֹל לִ֥֫י פִּתַּ֥חְתָּ שַׂקִּ֑י וַֽתְּאַזְּרֵ֥נִי שִׂמְחָֽה׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 13,
      "he": "לְמַ֤עַן&thinsp;׀ יְזַמֶּרְךָ֣ כָ֭בוֹד וְלֹ֣א יִדֹּ֑ם יְהֹוָ֥ה אֱ֝לֹהַ֗י לְעוֹלָ֥ם אוֹדֶֽךָּ׃ {פ}",
      "he_plain": "",
      "translit": "",
      "es": ""
    }
  ],
  "audio": ""
}