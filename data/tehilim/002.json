{
  "number": 2,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "לָ֭מָּה רָגְשׁ֣וּ גוֹיִ֑ם וּ֝לְאֻמִּ֗ים יֶהְגּוּ־רִֽיק׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 2,
      "he": "יִ֥תְיַצְּב֨וּ&thinsp;<b>׀</b> מַלְכֵי־אֶ֗רֶץ וְרוֹזְנִ֥ים נֽוֹסְדוּ־יָ֑חַד עַל־יְ֝הֹוָ֗ה וְעַל־מְשִׁיחֽוֹ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 3,
      "he": "נְֽ֭נַתְּקָה אֶת־מֽוֹסְרוֹתֵ֑ימוֹ וְנַשְׁלִ֖יכָה מִמֶּ֣נּוּ עֲבֹתֵֽימוֹ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 4,
      "he": "יוֹשֵׁ֣ב בַּשָּׁמַ֣יִם יִשְׂחָ֑ק אֲ֝דֹנָ֗י יִלְעַג־לָֽמוֹ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 5,
      "he": "אָ֤ז יְדַבֵּ֣ר אֵלֵ֣ימוֹ בְאַפּ֑וֹ וּֽבַחֲרוֹנ֥וֹ יְבַהֲלֵֽמוֹ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 6,
      "he": "וַ֭אֲנִי נָסַ֣כְתִּי מַלְכִּ֑י עַל־צִ֝יּ֗וֹן הַר־קׇדְשִֽׁי׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 7,
      "he": "אֲסַפְּרָ֗ה אֶֽ֫ל<span class=\"mam-implicit-maqaf\">־</span>חֹ֥ק יְֽהֹוָ֗ה אָמַ֘ר<span class=\"mam-implicit-maqaf\">־</span>אֵלַ֥י בְּנִ֥י אַ֑תָּה אֲ֝נִ֗י הַיּ֥וֹם יְלִדְתִּֽיךָ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 8,
      "he": "שְׁאַ֤ל מִמֶּ֗נִּי וְאֶתְּנָ֣ה ג֭וֹיִם נַחֲלָתֶ֑ךָ וַ֝אֲחֻזָּתְךָ֗ אַפְסֵי־אָֽרֶץ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 9,
      "he": "תְּ֭רֹעֵם בְּשֵׁ֣בֶט בַּרְזֶ֑ל כִּכְלִ֖י יוֹצֵ֣ר תְּנַפְּצֵֽם׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 10,
      "he": "וְ֭עַתָּה מְלָכִ֣ים הַשְׂכִּ֑ילוּ הִ֝וָּסְר֗וּ שֹׁ֣פְטֵי אָֽרֶץ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 11,
      "he": "עִבְד֣וּ אֶת־יְהֹוָ֣ה בְּיִרְאָ֑ה וְ֝גִ֗ילוּ בִּרְעָדָֽה׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 12,
      "he": "נַשְּׁקוּ־בַ֡ר פֶּן־יֶאֱנַ֤ף&thinsp;<b>׀</b> וְתֹ֬אבְדוּ דֶ֗רֶךְ כִּֽי־יִבְעַ֣ר כִּמְעַ֣ט אַפּ֑וֹ אַ֝שְׁרֵ֗י כׇּל־ח֥וֹסֵי בֽוֹ׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "he_plain": "",
      "translit": "",
      "es": ""
    }
  ],
  "audio": ""
}