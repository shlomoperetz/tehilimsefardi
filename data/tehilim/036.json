{
  "number": 36,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "לַמְנַצֵּ֬חַ&thinsp;׀&thinsp;לְעֶבֶד־יְהֹוָ֬ה לְדָוִֽד׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 2,
      "he": "נְאֻֽם־פֶּ֣שַׁע לָ֭רָשָׁע בְּקֶ֣רֶב לִבִּ֑י אֵֽין־פַּ֥חַד אֱ֝לֹהִ֗ים לְנֶ֣גֶד עֵינָֽיו׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 3,
      "he": "כִּֽי־הֶחֱלִ֣יק אֵלָ֣יו בְּעֵינָ֑יו לִמְצֹ֖א עֲוֺנ֣וֹ לִשְׂנֹֽא׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 4,
      "he": "דִּבְרֵי־פִ֭יו אָ֣וֶן וּמִרְמָ֑ה חָדַ֖ל לְהַשְׂכִּ֣יל לְהֵיטִֽיב׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 5,
      "he": "אָ֤וֶן&thinsp;׀ יַחְשֹׁ֗ב עַֽל־מִשְׁכָּ֫ב֥וֹ יִ֭תְיַצֵּב עַל־דֶּ֣רֶךְ לֹא־ט֑וֹב רָ֝֗ע לֹ֣א יִמְאָֽס׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 6,
      "he": "יְ֭הֹוָה בְּהַשָּׁמַ֣יִם חַסְדֶּ֑ךָ אֱ֝מ֥וּנָתְךָ֗ עַד־שְׁחָקִֽים׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 7,
      "he": "צִדְקָתְךָ֨&thinsp;׀ כְּֽהַרְרֵי־אֵ֗ל מִ֭שְׁפָּטֶיךָ תְּה֣וֹם רַבָּ֑ה אָ֤דָֽם־וּבְהֵמָ֖ה תוֹשִׁ֣יעַ יְהֹוָֽה׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 8,
      "he": "מַה־יָּקָ֥ר חַסְדְּךָ֗ אֱלֹ֫הִ֥ים וּבְנֵ֥י אָדָ֑ם בְּצֵ֥ל כְּ֝נָפֶ֗יךָ יֶחֱסָיֽוּן׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 9,
      "he": "יִ֭רְוְיֻן מִדֶּ֣שֶׁן בֵּיתֶ֑ךָ וְנַ֖חַל עֲדָנֶ֣יךָ תַשְׁקֵֽם׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 10,
      "he": "כִּֽי־עִ֭מְּךָ מְק֣וֹר חַיִּ֑ים בְּ֝אוֹרְךָ֗ נִרְאֶה־אֽוֹר׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 11,
      "he": "מְשֹׁ֣ךְ חַ֭סְדְּךָ לְיֹדְעֶ֑יךָ וְ֝צִדְקָתְךָ֗ לְיִשְׁרֵי־לֵֽב׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 12,
      "he": "אַל־תְּ֭בוֹאֵנִי רֶ֣גֶל גַּאֲוָ֑ה וְיַד־רְ֝שָׁעִ֗ים אַל־תְּנִדֵֽנִי׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 13,
      "he": "שָׁ֣ם נָ֭פְלוּ פֹּ֣עֲלֵי אָ֑וֶן דֹּ֝ח֗וּ וְלֹא־יָ֥כְלוּ קֽוּם׃ {פ}",
      "he_plain": "",
      "translit": "",
      "es": ""
    }
  ],
  "audio": ""
}