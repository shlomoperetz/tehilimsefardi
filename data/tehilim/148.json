{
  "number": 148,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "הַ֥לְלוּ־יָ֨הּ&thinsp;׀ הַֽלְל֣וּ אֶת־יְ֭הֹוָה מִן־הַשָּׁמַ֑יִם הַֽ֝לְל֗וּהוּ בַּמְּרוֹמִֽים׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 2,
      "he": "הַֽלְל֥וּהוּ כׇל־מַלְאָכָ֑יו הַ֝לְל֗וּהוּ כׇּל־צְבָאָֽו׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 3,
      "he": "הַֽ֭לְלוּהוּ שֶׁ֣מֶשׁ וְיָרֵ֑חַ הַֽ֝לְל֗וּהוּ כׇּל־כּ֥וֹכְבֵי אֽוֹר׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 4,
      "he": "הַֽ֭לְלוּהוּ שְׁמֵ֣י הַשָּׁמָ֑יִם וְ֝הַמַּ֗יִם אֲשֶׁ֤ר&thinsp;׀ מֵעַ֬ל הַשָּׁמָֽיִם׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 5,
      "he": "יְֽ֭הַלְלוּ אֶת־שֵׁ֣ם יְהֹוָ֑ה כִּ֤י ה֖וּא צִוָּ֣ה וְנִבְרָֽאוּ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 6,
      "he": "וַיַּעֲמִידֵ֣ם לָעַ֣ד לְעוֹלָ֑ם חׇק־נָ֝תַ֗ן וְלֹ֣א יַעֲבֽוֹר׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 7,
      "he": "הַֽלְל֣וּ אֶת־יְ֭הֹוָה מִן־הָאָ֑רֶץ תַּ֝נִּינִ֗ים וְכׇל־תְּהֹמֽוֹת׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 8,
      "he": "אֵ֣שׁ וּ֭בָרָד שֶׁ֣לֶג וְקִיט֑וֹר ר֥וּחַ סְ֝עָרָ֗ה עֹשָׂ֥ה דְבָרֽוֹ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 9,
      "he": "הֶהָרִ֥ים וְכׇל־גְּבָע֑וֹת עֵ֥ץ פְּ֝רִ֗י וְכׇל־אֲרָזִֽים׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 10,
      "he": "הַחַיָּ֥ה וְכׇל־בְּהֵמָ֑ה רֶ֝֗מֶשׂ וְצִפּ֥וֹר כָּנָֽף׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 11,
      "he": "מַלְכֵי־אֶ֭רֶץ וְכׇל־לְאֻמִּ֑ים שָׂ֝רִ֗ים וְכׇל־שֹׁ֥פְטֵי אָֽרֶץ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 12,
      "he": "בַּחוּרִ֥ים וְגַם־בְּתוּל֑וֹת זְ֝קֵנִ֗ים עִם־נְעָרִֽים׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 13,
      "he": "יְהַלְל֤וּ&thinsp;׀ אֶת־שֵׁ֬ם יְהֹוָ֗ה כִּֽי־נִשְׂגָּ֣ב שְׁמ֣וֹ לְבַדּ֑וֹ ה֝וֹד֗וֹ עַל־אֶ֥רֶץ וְשָׁמָֽיִם׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 14,
      "he": "וַיָּ֤רֶם קֶ֨רֶן&thinsp;׀ לְעַמּ֡וֹ תְּהִלָּ֤ה לְֽכׇל־חֲסִידָ֗יו לִבְנֵ֣י יִ֭שְׂרָאֵל עַ֥ם קְרֹב֗וֹ הַֽלְלוּ־יָֽהּ׃ {פ}",
      "he_plain": "",
      "translit": "",
      "es": ""
    }
  ],
  "audio": ""
}