{
  "number": 82,
  "title_he": "תהילים",
  "verses": [
    {
      "num": 1,
      "he": "מִזְמ֗וֹר לְאָ֫סָ֥ף אֱֽלֹהִ֗ים נִצָּ֥ב בַּעֲדַת־אֵ֑ל בְּקֶ֖רֶב אֱלֹהִ֣ים יִשְׁפֹּֽט׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 2,
      "he": "עַד־מָתַ֥י תִּשְׁפְּטוּ־עָ֑וֶל וּפְנֵ֥י רְ֝שָׁעִ֗ים תִּשְׂאוּ־סֶֽלָה׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 3,
      "he": "שִׁפְטוּ־דַ֥ל וְיָת֑וֹם עָנִ֖י וָרָ֣שׁ הַצְדִּֽיקוּ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 4,
      "he": "פַּלְּטוּ־דַ֥ל וְאֶבְי֑וֹן מִיַּ֖ד רְשָׁעִ֣ים הַצִּֽילוּ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 5,
      "he": "לֹ֤א יָדְע֨וּ&thinsp;<b>׀</b> וְלֹ֥א יָבִ֗ינוּ בַּחֲשֵׁכָ֥ה יִתְהַלָּ֑כוּ יִ֝מּ֗וֹטוּ כׇּל־מ֥וֹסְדֵי אָֽרֶץ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 6,
      "he": "אֲֽנִי־אָ֭מַרְתִּי אֱלֹהִ֣ים אַתֶּ֑ם וּבְנֵ֖י עֶלְי֣וֹן כֻּלְּכֶֽם׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 7,
      "he": "אָ֭כֵן כְּאָדָ֣ם תְּמוּת֑וּן וּכְאַחַ֖ד הַשָּׂרִ֣ים תִּפֹּֽלוּ׃",
      "he_plain": "",
      "translit": "",
      "es": ""
    },
    {
      "num": 8,
      "he": "קוּמָ֣ה אֱ֭לֹהִים שׇׁפְטָ֣ה הָאָ֑רֶץ כִּֽי־אַתָּ֥ה תִ֝נְחַ֗ל בְּכׇל־הַגּוֹיִֽם׃&nbsp;<span class=\"mam-spi-pe\">{פ}</span><br>",
      "he_plain": "",
      "translit": "",
      "es": ""
    }
  ],
  "audio": ""
}